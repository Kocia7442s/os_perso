# =========================================================
#  OS Perso — MODÈLE de variables d'environnement (COMMITÉ)
#  Copie ce fichier en ".env" puis remplis avec tes vraies
#  valeurs :  cp .env.example .env
# =========================================================

# --- Base de données MariaDB ---
DB_ROOT_PASSWORD=change_me_root
DB_NAME=os_perso
DB_USER=os_user
DB_PASSWORD=change_me_user

# Hôte interne de la BDD vu par PHP (= nom du service Docker, PAS localhost).
DB_HOST=db

# --- Ports exposés sur la machine hôte ---
WEB_PORT=8088
DB_PORT=3307

# --- IA (Anthropic Claude) ---
# Clé API à créer sur https://console.anthropic.com/ (format sk-ant-...).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Modèle utilisé. claude-haiku-4-5 = rapide/éco ; claude-sonnet-4-6 = plus costaud.
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Divers ---
TZ=Europe/Paris
